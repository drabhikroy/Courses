summarize(Throws = first(p_throws),
N_in = sum(InZone),
N_out = sum(1 - InZone),
M_in = sum(InZone * Miss),
M_out = sum((1 - InZone) * Miss)) -> S2
S2 %>%
filter(N_in + N_out >= 300) %>%
ggplot(aes(100 * M_in / N_in,
100 * M_out / N_out)) +
geom_point() +
xlab("Miss Rate in Zone") +
ylab("Miss Rate out of Zone")
inner_join(S2, chadwick,
by = c("pitcher" = "key_mlbam")) -> S2
S2 %>%
filter(N_in + N_out >= 300) -> S2_300
ggplot(S2_300,
aes(100 * M_in / N_in,
100 * M_out / N_out,
label = name_last)) +
geom_point() +
xlab("Miss Rate in Zone") +
ylab("Miss Rate out of Zone") +
geom_text_repel(data =
filter(S2_300,
name_last == "Scherzer"),
color = "red", size = 5) +
geom_text_repel(data =
filter(S2_300,
name_last == "Gibson"),
color = "red", size = 5) +
ggtitle("Miss Rates (%) In and Out of Zone") +
centertitle() +
increasefont()
slider_swing_R <- filter(slider_swing,
p_throws == "R")
fit <- gam(Miss ~ s(plate_x, plate_z),
data = slider_swing_R,
family = binomial)
slider_swing_R_sample <-
sample_n(slider_swing_R, size = 500)
slider_swing_R_sample$Prob <- predict(fit,
slider_swing_R_sample,
type = "response")
ggplot(slider_swing_R_sample,
aes(plate_x, plate_z, color = Prob)) +
geom_point() +
add_zone("black")  +
coord_fixed() +
ylim(0.0, 4.0) +
scale_color_continuous(low = "blue", high = "red") +
increasefont() +
ggtitle("Sample of Pitches Colored by Prob(Miss)") +
centertitle()
out_R_SL <- re_offspeed(sc_pitcher_2019,
"R", "SL", 500)
out_R_SL$p
